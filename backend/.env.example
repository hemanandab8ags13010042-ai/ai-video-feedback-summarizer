PORT=5000
# REQUIRED IN PRODUCTION — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
NODE_ENV=development

# Database Configuration (MySQL)
# If these are not provided, the application will fallback to a local SQLite database automatically.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ai_video_feedback
DB_PORT=3306

# Cloudinary Configuration (For file uploads)
# If these are not provided, file uploads will fall back to local disk storage in backend/uploads.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI API Keys
# Gemini API Key (Recommended)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI API Key (Optional fallback)
OPENAI_API_KEY=your_openai_api_key

# Groq API Key (Optional fallback)
GROQ_API_KEY=your_groq_api_key

# SMTP Configuration (For email notifications - default fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="DigiQuest Studio Alerts" <your_email@gmail.com>

# HTTP Email Services (Bypasses SMTP port blocks on platforms like Render)
# Set either of these keys to automatically use HTTP APIs instead of SMTP
RESEND_API_KEY=
# Optional: Set a custom sender email verified on your Resend account (e.g. "DigiQuest Studio <alerts@yourdomain.com>")
# If not specified, it will default to "DigiQuest Studio <onboarding@resend.dev>"
RESEND_FROM=

BREVO_API_KEY=


