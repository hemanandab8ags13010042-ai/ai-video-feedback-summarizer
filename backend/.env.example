PORT=5000
JWT_SECRET=supersecretjwtkeyforfeedbacksummarizer
NODE_ENV=development

# Database Configuration (MySQL)
# If these are not provided, the application will fallback to a local SQLite database automatically.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ai_video_feedback
DB_PORT=3306

# Cloudinary Configuration (For file uploads)
# If these are not provided, file uploads will fall back to local disk storage in backend/uploads.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI API Keys
# Gemini API Key (Recommended)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI API Key (Optional fallback)
OPENAI_API_KEY=your_openai_api_key
